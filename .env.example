SERVICE_NAME=arisha-payments
LOG_LEVEL=INFO
ENVIRONMENT=dev

API_HOST=0.0.0.0
API_PORT=8000
API_KEY=dev-secret-key-change-me

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=payments
POSTGRES_PASSWORD=payments
POSTGRES_DB=payments
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/
RABBITMQ_MANAGEMENT_PORT=15672

PAYMENTS_EXCHANGE=payments
PAYMENTS_RETRY_EXCHANGE=payments.retry
PAYMENTS_DLX=payments.dlx
PAYMENTS_NEW_QUEUE=payments.new
PAYMENTS_RETRY_QUEUE=payments.retry
PAYMENTS_DLQ=payments.dlq
PAYMENTS_ROUTING_KEY=payment.created
PAYMENTS_FAILED_ROUTING_KEY=payment.failed

OUTBOX_POLL_INTERVAL_MS=200
OUTBOX_BATCH_SIZE=50
OUTBOX_MAX_ATTEMPTS=5

CONSUMER_PREFETCH=10
WEBHOOK_TIMEOUT_S=10.0
WEBHOOK_MAX_ATTEMPTS=3
WEBHOOK_RETRY_BASE_DELAY_S=1.0
PAYMENTS_MAX_ATTEMPTS=3
PAYMENTS_RETRY_BASE_DELAY_S=1.0

GATEWAY_MIN_DELAY_S=2.0
GATEWAY_MAX_DELAY_S=5.0
GATEWAY_SUCCESS_RATE=0.9

WEBHOOK_RECEIVER_HOST=0.0.0.0
WEBHOOK_RECEIVER_PORT=9000
